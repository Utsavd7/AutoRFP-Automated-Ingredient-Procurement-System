# ============================================================
# AutoRFP - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#
# .env is gitignored. Do not commit real keys.
# ============================================================


# ------------------------------------------------------------
# DATABASE
# Required for the procurement database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ------------------------------------------------------------
DATABASE_URL="postgresql://your_user@localhost:5432/autorfp"


# ------------------------------------------------------------
# NEXTAUTH
# Required for restaurant workspace sessions.
# Generate a local secret:
#   openssl rand -base64 32
# ------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""


# ------------------------------------------------------------
# GROQ
# Required for the full demo AI path and Ollama fallback.
# Used for menu parsing fallback, recommendations, quote simulation,
# inbound email parsing, and the agent negotiation pipeline.
#
# Get a key: https://console.groq.com/keys
# ------------------------------------------------------------
GROQ_API_KEY=""


# ------------------------------------------------------------
# OLLAMA
# Optional local AI. If Ollama is not running, chat calls fall back
# to Groq and embeddings use a deterministic local fallback.
#
# Optional setup:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
# ------------------------------------------------------------
OLLAMA_URL="http://localhost:11434"


# ------------------------------------------------------------
# CHROMADB
# Optional vector store for RAG procurement memory.
# If ChromaDB is unavailable, RAG is skipped gracefully.
#
# Optional setup:
#   chroma run --path ./chroma_data
# ------------------------------------------------------------
CHROMA_URL="http://localhost:8000"


# ------------------------------------------------------------
# GOOGLE PLACES
# Optional real supplier discovery. If missing, the app uses the
# curated distributor fallback pool.
#
# Enable Places API in Google Cloud if you use this.
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""


# ------------------------------------------------------------
# EMAIL DELIVERY
# Optional. Without RESEND_API_KEY, RFPs are stored/logged only.
# MOCK_EMAIL routes demo vendor emails to one inbox.
# ------------------------------------------------------------
RESEND_API_KEY=""
MOCK_EMAIL=""


# ------------------------------------------------------------
# BUYER REPORTS
# Optional. Buyer reports are off unless explicitly enabled.
# Requires RESEND_API_KEY when enabled.
# ------------------------------------------------------------
AUTORFP_SEND_BUYER_REPORT="false"
BUYER_EMAIL=""
