generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Menu {
  id        String   @id @default(uuid())
  sourceUrl String?
  text      String?
  rfps      RFP[]
  recipes   Recipe[]
}

model Recipe {
  id          String       @id @default(uuid())
  name        String
  menuId      String
  ingredients Ingredient[]
  menu        Menu         @relation(fields: [menuId], references: [id])
}

model Ingredient {
  id            String         @id @default(uuid())
  name          String
  quantity      Float?
  unit          String?
  recipeId      String
  recipe        Recipe         @relation(fields: [recipeId], references: [id])
  pricingTrends PricingTrend[]
}

model PricingTrend {
  id           String     @id @default(uuid())
  ingredientId String
  price        Float
  date         DateTime
  source       String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Distributor {
  id          String  @id @default(uuid())
  name        String
  contactName String?
  email       String
  location    String
  rfps        RFP[]
}

model RFP {
  id            String      @id @default(uuid())
  menuId        String
  distributorId String
  status        String
  sentAt        DateTime?
  createdAt     DateTime    @default(now())
  quotes        Quote[]
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  menu          Menu        @relation(fields: [menuId], references: [id])
}

model Quote {
  id      String  @id @default(uuid())
  rfpId   String
  price   Float
  details String?
  rfp     RFP     @relation(fields: [rfpId], references: [id])
}
