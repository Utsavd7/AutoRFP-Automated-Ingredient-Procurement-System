# ============================================================
# AutoRFP - Environment Variables Sample
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.sample .env
#
# .env is already gitignored — never commit your real keys!
# ============================================================


# ------------------------------------------------------------
# 1. GEMINI API KEY (REQUIRED)
#    Used for: Menu parsing (AI recipe extraction) and
#              inbound email parsing (vendor quote extraction)
#
#    How to get it:
#    a) Go to https://aistudio.google.com/app/apikey
#    b) Sign in with your Google account
#    c) Click "Create API Key" → "Create API key in new project"
#    d) Copy the generated key and paste it below
# ------------------------------------------------------------
GEMINI_API_KEY=""


# ------------------------------------------------------------
# 2. GOOGLE MAPS / PLACES API KEY (OPTIONAL)
#    Used for: Finding real local food wholesale distributors
#              near a given city or zip code.
#    Note: If left empty, the app uses mock distributor data.
#
#    How to get it:
#    a) Go to https://console.cloud.google.com/
#    b) Create a new project (or select an existing one)
#    c) Go to "APIs & Services" → "Library"
#    d) Search for "Places API (New)" and click "Enable"
#    e) Go to "APIs & Services" → "Credentials"
#    f) Click "Create Credentials" → "API Key"
#    g) (Recommended) Click "Restrict Key":
#       - Under "API restrictions", select "Restrict key"
#       - Choose "Places API (New)" from the dropdown
#    h) Copy the key and paste it below
#
#    Billing note: Google requires a billing account to be
#    linked, but offers a $200/month free credit which covers
#    thousands of Places API calls.
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""


# ------------------------------------------------------------
# 3. DATABASE URL (REQUIRED — default works out of the box)
#    Used for: Storing menus, recipes, distributors, RFPs,
#              and vendor quotes via Prisma + SQLite.
#
#    No setup needed — Prisma automatically creates the
#    local dev.db file when you run:
#      npx prisma db push
# ------------------------------------------------------------
DATABASE_URL="file:./dev.db"
