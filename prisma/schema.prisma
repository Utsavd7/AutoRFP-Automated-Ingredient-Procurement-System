generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Menu {
  id                 String   @id @default(uuid())
  tenantId           String?
  sourceUrl          String?
  text               String?
  mealName           String?
  guestCount         Int?
  bufferPct          Float?
  requestedIngredients Json?
  workflowStatus     String   @default("DRAFT")
  lastActivityAt     DateTime @default(now())
  rfps               RFP[]
  recipes            Recipe[]
  tenant             Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Tenant {
  id                 String              @id
  restaurantName     String
  email              String
  passwordHash       String?
  passwordSalt       String?
  location           String
  cuisineType        String?
  preferredSuppliers String[]
  monthlyBudgetTarget Float?
  savingsTargetPct   Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  menus              Menu[]
  procurementRuns    ProcurementRun[]
}

model Recipe {
  id          String       @id @default(uuid())
  name        String
  menuId      String
  ingredients Ingredient[]
  menu        Menu         @relation(fields: [menuId], references: [id])
}

model Ingredient {
  id            String         @id @default(uuid())
  name          String
  quantity      Float?
  unit          String?
  recipeId      String
  recipe        Recipe         @relation(fields: [recipeId], references: [id])
  pricingTrends PricingTrend[]
}

model PricingTrend {
  id           String     @id @default(uuid())
  ingredientId String
  price        Float
  date         DateTime
  source       String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

model Distributor {
  id          String  @id @default(uuid())
  name        String
  contactName String?
  email       String
  location    String
  rfps        RFP[]
}

model RFP {
  id            String      @id @default(uuid())
  menuId        String
  tenantId      String?
  distributorId String
  status        String
  sentAt        DateTime?
  viewedAt      DateTime?
  repliedAt     DateTime?
  negotiatedAt  DateTime?
  acceptedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  statusUpdatedAt DateTime  @default(now()) @updatedAt
  quotes        Quote[]
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  menu          Menu        @relation(fields: [menuId], references: [id])

  @@index([tenantId])
  @@index([menuId, tenantId])
}

model Quote {
  id          String   @id @default(uuid())
  rfpId       String
  price       Float
  details     String?
  status      String   @default("SUBMITTED")
  submittedAt DateTime @default(now())
  rfp         RFP      @relation(fields: [rfpId], references: [id])
}

model ProcurementRun {
  id                String   @id @default(uuid())
  tenantId          String
  menuText          String?
  totalSpend        Float?
  totalSavings      Float?
  savingsPercentage Float?
  bestVendor        String?
  winnerPrice       Float?
  recipesCount      Int      @default(0)
  ingredientsCount  Int      @default(0)
  distributorsCount Int      @default(0)
  quotesCount       Int      @default(0)
  executiveSummary  String?
  marketAlerts      String[]
  createdAt         DateTime @default(now())
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}
