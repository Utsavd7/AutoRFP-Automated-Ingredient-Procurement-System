# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────
/.next/
/out/
/build

# ── Environment files (never commit real keys) ────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.sample is intentionally NOT listed here — commit it

# ── Prisma generated client ───────────────────────────────
/src/generated/prisma

# ── Database files ────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────────────────
/coverage

# ── Vercel ────────────────────────────────────────────────
.vercel

# ── ChromaDB vector store data ────────────────────────────
/chroma_data/

