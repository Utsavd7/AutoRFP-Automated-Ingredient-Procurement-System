# ============================================================
# AutoRFP — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#
# .env is gitignored — never commit real keys.
# ============================================================


# ------------------------------------------------------------
# DATABASE (REQUIRED)
# PostgreSQL connection string.
#
# Local setup:
#   brew services start postgresql@15   # macOS
#   createdb autorfp
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ------------------------------------------------------------
DATABASE_URL="postgresql://your_user@localhost:5432/autorfp"


# ------------------------------------------------------------
# GROQ API KEY (REQUIRED)
# Cross-verifies every AI decision against Ollama's local output.
# Also handles menu parsing when Ollama returns bad JSON, and
# powers the 5-agent negotiation pipeline.
#
# Get a free key at: https://console.groq.com/keys
# Free tier — no credit card required.
# ------------------------------------------------------------
GROQ_API_KEY=""


# ------------------------------------------------------------
# OLLAMA — LOCAL LLM (REQUIRED, no key needed)
# Runs llama3.2 locally as the primary AI model.
# Ollama is free and runs entirely on your machine.
#
# Install: https://ollama.com
# Then pull the model:
#   ollama pull llama3.2
#
# No key or env var needed — the app connects to localhost:11434.
# ------------------------------------------------------------


# ------------------------------------------------------------
# GOOGLE MAPS API KEY (REQUIRED)
# Used to find real food distributors near a city or zip code
# via the Places Text Search API.
#
# Get a key at: https://console.cloud.google.com
# Enable: Places API
# Note: Billing must be enabled on the Cloud project.
#       $200/month free credit covers ~11,700 searches.
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=""


# ------------------------------------------------------------
# RESEND API KEY (OPTIONAL)
# Enables real email delivery of RFPs to distributors.
# If not set, RFPs are saved to the database only (no email sent).
#
# Get a free key at: https://resend.com
# Free tier: 100 emails/day.
# ------------------------------------------------------------
RESEND_API_KEY=""


# ------------------------------------------------------------
# MOCK EMAIL (OPTIONAL)
# When set, all distributor contact emails are replaced with
# this address. Useful during development to inspect RFP emails
# without sending to real vendor addresses.
#
# Example: MOCK_EMAIL="you@gmail.com"
# ------------------------------------------------------------
MOCK_EMAIL=""
